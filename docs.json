            "pages": [
              "addresses/crypto-addresses",
              "addresses/bank-accounts"
            ]
          },
          {
            "group": "Virtual Accounts",
            "pages": [
              "virtual-accounts/virtual-accounts-guide"
            ]
          },
          {
            "group": "Autoramp & Transactions",
